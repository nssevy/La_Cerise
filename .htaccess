RewriteEngine On
RewriteBase /La_Cerise/

# Page d'accueil

RewriteRule ^$ controller/index.php [L]

# Laisser passer les fichiers existants (assets, images, css...)

RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Laisser passer les dossiers existants sauf la racine

RewriteCond %{REQUEST_URI} !^/$
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route article : /article/mon-slug

RewriteRule ^article/([^/]+)/?$ controller/article.php?slug=$1 [L,QSA]

# Toutes les autres routes : /lexique → controller/lexique.php

RewriteRule ^(.+?)(?:\.php)?$ controller/$1.php [L]
