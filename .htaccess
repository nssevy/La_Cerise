RewriteEngine On
RewriteBase /La_Cerise/

# Page d'accueil
RewriteRule ^$ controller/public/index.php [L]

# Laisser passer les fichiers existants (assets, images, css...)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Laisser passer les dossiers existants sauf la racine
RewriteCond %{REQUEST_URI} !^/$
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route article : /article/mon-slug
RewriteRule ^article/([^/]+)/?$ controller/public/article.php?slug=$1 [L,QSA]

# Route lexique
RewriteRule ^lexique/?$ controller/public/lexique.php [L]

# Route Tout les Articles
RewriteRule ^allArticles/?$ controller/public/allArticles.php [L]

# Routes légales
RewriteRule ^legal/cgu/?$ controller/public/legal.php?type=cgu [L,QSA]
RewriteRule ^legal/confidentialite/?$ controller/public/legal.php?type=confidentialite [L,QSA]
RewriteRule ^legal/mentions_legales/?$ controller/public/legal.php?type=mentions_legales [L,QSA]

# Routes paramètre
RewriteRule ^admin/parametre/?$ controller/admin/parametre/index.php [L]
RewriteRule ^admin/parametre/update-profil/?$ controller/admin/parametre/update-profil.php [L]
RewriteRule ^admin/parametre/legal/edit/?$ controller/admin/parametre/legal/edit.php [L,QSA]

# Route newsletter
RewriteRule ^newsletter/?$ controller/public/newsletter.php [L]

RewriteRule ^404\.php$ 404.php [L]

# Routes admin
RewriteRule ^admin/(.+?)(?:\.php)?$ controller/admin/$1.php [L]

# Page 404
ErrorDocument 404 /La_Cerise/404.php


