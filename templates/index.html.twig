{% extends 'base.html.twig' %}

{% block titre %}La Cerise
{% endblock %}

{% block content %}
	<section class="flex flex-col gap-10 my-20">

		<article>
			<a href="/La_Cerise/public/article.php?slug={{ hero.slug }}" class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-50">

				<div class="flex flex-col justify-between gap-10 lg:gap-0">
					<div class="flex flex-col gap-5">
						<h1>{{ hero.titre }}</h1>
						<img src="/La_Cerise/assets/images/{{ hero.image_principale }}" class="w-full h-full object-cover aspect-3/2 overflow-hidden md:hidden" alt="{{ hero.titre }}">
						<small>{{ hero.chapeau }}</small>
					</div>

					<div class="flex justify-between">
						<small>{{ formatDateFr(hero.date_publication) }}</small>
						<small class="text-neutral-400">{{ hero.rubrique }}</small>
					</div>
				</div>

				<div class="hidden lg:flex flex-col gap-5">
					<img src="/La_Cerise/assets/images/{{ hero.image_principale }}" class="w-full h-full object-cover aspect-square overflow-hidden" alt="{{ hero.titre }}">
					<small class="text-neutral-400">{{ hero.credit_photo }}</small>
				</div>

			</a>
		</article>

		<div class="flex flex-col gap-10 md:grid grid-cols-2 grid-rows-1 gap-4">
			{% for card in cards %}
				<article class="flex flex-col gap-5 h-full">
					<a href="/La_Cerise/public/article.php?slug={{ card.slug }}" class="flex flex-col justify-between h-full gap-10">
						<div class="flex flex-col gap-5">
							<h2>{{ card.titre }}</h2>
							<small>{{ card.chapeau }}</small>
						</div>
						<div class="flex justify-between">
							<small>{{ formatDateFr(card.date_publication) }}</small>
							<small class="text-neutral-400">{{ card.rubrique }}</small>
						</div>
					</a>
				</article>
			{% endfor %}
		</div>

	</section>
{% endblock %}
