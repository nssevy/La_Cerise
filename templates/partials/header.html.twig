{% import 'macros/icons.html.twig' as icons %}
<header class="w-full sticky top-0 z-60 bg-white border-b border-(--09)">
	<div class="flex items-center justify-between py-4 max-w-7xl mx-auto px-4 md:px-8 lg:px-12">

		<a href="{{ base }}/">
			<div class="relative h-8">
				<img src="{{ base }}/assets/images/favicon/svg/Cerise-FullLogo.svg" alt="" class="h-8 w-auto absolute top-0 left-0 blur-md opacity-50">
				<img src="{{ base }}/assets/images/favicon/svg/Cerise-FullLogo.svg" alt="" class="h-8 w-auto relative">
			</div>
		</a>

		<nav class="hidden md:flex items-center gap-8 text-body uppercase text-(--01) whitespace-nowrap">
			<a href="{{ base }}/allArticles" class="hocus:text-(--special) transition-colors">Articles</a>
			<a href="{{ base }}/lexique" class="hocus:text-(--special) transition-colors">Lexique</a>
		</nav>


		<div class="flex items-center gap-4">
			<a class="hidden md:block text-body uppercase text-(--01) whitespace-nowrap hocus:text-(--special) transition-colors" href="mailto:contact@lacerise.blog?subject=Contact%20La%20Cerise">Me contacter</a>
			<button id="menu-btn" class="md:hidden text-(--01) cursor-pointer" aria-label="Ouvrir le menu" aria-expanded="false">
				<span id="icon-open">Menu</span>
				<span id="icon-close" class="hidden">Fermer</span>
			</button>
		</div>

	</div>
</header>
