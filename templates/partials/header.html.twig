{% import 'macros/icons.html.twig' as icons %}
<header class="w-full sticky top-0 z-60 bg-white border-b border-(--09)">
	<div class="flex items-center justify-between py-4 max-w-7xl mx-auto px-4 md:px-8 lg:px-12">

		<nav class="hidden md:flex items-center gap-5 text-body uppercase text-(--01) whitespace-nowrap">
			<a href="{{ base }}/lexique" class="hocus:text-(--special) transition-colors">Lexique</a>
		</nav>

		<a href="{{ base }}/">
			<div class="relative h-8">
				<img src="{{ base }}/assets/images/Logo.png" alt="" class="h-8 w-auto absolute top-0 left-0 blur-md opacity-50">
				<img src="{{ base }}/assets/images/Logo.png" alt="La Cerise" class="h-8 w-auto relative">
			</div>
		</a>

		<div class="flex items-center gap-4">
			<a class="hidden md:block text-body uppercase text-(--01) whitespace-nowrap hocus:text-(--special) transition-colors" href="mailto:contact@lacerise.blog?subject=Contact%20La%20Cerise">Me contacter</a>
			<button id="menu-btn" class="md:hidden text-(--01)" aria-label="Ouvrir le menu" aria-expanded="false">
				<span id="icon-open" class="w-6 h-6 inline-flex items-center justify-center">
					{{ icons.icon('list', 'bold', 'w-6 h-6') }}
				</span>
				<span id="icon-close" class="w-6 h-6 inline-flex items-center justify-center" style="display:none">
					{{ icons.icon('x', 'bold', 'w-6 h-6') }}
				</span>
			</button>
		</div>

	</div>
</header>
