<!DOCTYPE html>
<html lang="fr">

	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block titre %}La Cerise
			{% endblock %}
		</title>
		<link rel="stylesheet" href="{{ base }}/assets/css/output.css">
		<link rel="icon" type="image/x-icon" href="{{ base }}/assets/images/favicon/favicon.ico">
		<link rel="icon" type="image/png" sizes="32x32" href="{{ base }}/assets/images/favicon/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="{{ base }}/assets/images/favicon/favicon-16x16.png">
		<link rel="apple-touch-icon" sizes="180x180" href="{{ base }}/assets/images/favicon/apple-touch-icon.png">
		<link rel="stylesheet" href="https://unpkg.com/lucide-static@latest/font/lucide.css"> {% block styles %}{% endblock %}
		</head>

		<body>

			<header class="w-full sticky top-0 z-50 bg-white border-b border-[var(--09)]">
				<div class="flex items-center justify-between px-12 py-4">

					<a href="{{ base }}/">
						<div class="relative h-8">
							<img
							{# flouté #} src="{{ base }}/assets/images/Logo.png" alt="" class="h-8 w-auto absolute top-0 left-0 blur-md opacity-50">
							{# pas flouté #}
							<img src="{{ base }}/assets/images/Logo.png" alt="La Cerise" class="h-8 w-auto relative">
						</div>
					</a>

					<nav class="hidden md:flex items-center gap-5 text-body uppercase text-[var(--01)] whitespace-nowrap">
						<a href="#" class="hover:text-[var(--special)] transition-colors">S'abonner</a>
						<a href="#" class="hover:text-[var(--special)] transition-colors">Articles</a>
						<a href="{{ base }}/lexique.php" class="hover:text-[var(--special)] transition-colors">Lexique</a>
					</nav>

					<div class="flex items-center gap-4">
						<a href="#" class="hidden md:block text-body uppercase text-[var(--01)] whitespace-nowrap hover:text-[var(--special)] transition-colors">
							Me contacter
						</a>
						<button id="menu-btn" class="md:hidden" aria-label="Ouvrir le menu" aria-expanded="false">
							<div id="icon-open" class="icon-menu text-2xl"></div>
							<div id="icon-close" class="icon-x text-2xl hidden"></div>
						</button>
					</div>

				</div>

				<nav id="mobile-menu" class="hidden md:hidden flex-col gap-4 px-12 pb-6 pt-2 border-t border-[var(--09)] bg-white">
					<a href="#" class="block text-body uppercase text-[var(--01)] py-2 hover:text-[var(--special)] transition-colors">S'abonner</a>
					<a href="#" class="block text-body uppercase text-[var(--01)] py-2 hover:text-[var(--special)] transition-colors">Articles</a>
					<a href="{{ base }}/lexique.php" class="block text-body uppercase text-[var(--01)] py-2 hover:text-[var(--special)] transition-colors">Lexique</a>
					<a href="#" class="block text-body uppercase text-[var(--01)] py-2 hover:text-[var(--special)] transition-colors">Me contacter</a>
				</nav>

			</header>

			<script src="{{ base }}/assets/js/menu.js" defer></script>

			{% block main_class %}
				<main class="w-5/6 mx-auto">
				{% endblock %}

				{% block content %}{% endblock %}

			</main>

			<footer>
				<div class="px-12 py-12 flex flex-col md:flex-row items-start md:items-center justify-between gap-12">
					<div class="flex flex-col justify-between h-48 md:h-60">
						<p class="text-5xl md:text-[52px] font-light leading-none text-[var(--01)]">La cerise</p>
						<p class="text-2xl font-light leading-none text-[var(--01)]">On apprend à tout âge.</p>
					</div>

					<div class="flex flex-col gap-6 w-full md:w-72 md:items-end">
						<p class="text-3xl md:text-[40px] font-light leading-tight text-[var(--01)] md:text-right">
							Inscrivez-vous à notre newsletter
						</p>
						<p class="text-xs font-light text-[var(--01)]">Restez au courant des dernières sorties.</p>
						<form action="#" method="post" class="w-full flex flex-col gap-3">
							<div class="flex items-center justify-between text-xs w-full gap-4">
								<input type="email" name="email" placeholder="Saisissez votre email ici..." required class="bg-transparent outline-none flex-1 text-[var(--01)] placeholder:text-[var(--06)]">
								<button type="submit" class="text-[var(--01)] whitespace-nowrap hover:text-[var(--special)] transition-colors cursor-pointer">
									Inscrivez-vous
								</button>
							</div>
							<hr class="border-t border-[var(--01)]">
						</form>
					</div>
				</div>

				<div class="px-12 pb-8 flex flex-col md:flex-row items-center justify-center gap-8 md:gap-16 text-xs text-[var(--01)] font-light">
					<a href="#" class="hover:text-[var(--special)] transition-colors whitespace-nowrap">Mentions légales</a>
					<p class="whitespace-nowrap">© 2026 La Cerise - Tous droits réservés.</p>
				</div>
			</footer>

			{% block scripts %}{% endblock %}

		</body>
	</html>
