{# Liste d'articles sous le carousel — 3 max + bouton "voir plus" #}
{% if gridArticles is defined and gridArticles is not empty %}
	<section class="max-w-3xl mx-auto px-4 md:px-8 lg:px-12 mt-16 mb-20">
		{% for article in gridArticles | slice(0, 3) %}
			<hr class="border-0.5 border-cerise-08 border-dashed">
			<a href="{{ base }}/article/{{ article.slug }}" class="group flex flex-col md:flex-row gap-8 md:gap-10 items-start py-8">
				{% if article.image_principale is not empty %}
					<div class="overflow-hidden aspect-3/2 w-full md:w-64 shrink-0">
						<img src="{{ base }}/assets/images/{{ article.image_principale }}" alt="{{ article.titre }}" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105 rounded-sm">
					</div>
				{% endif %}
				<div class="flex flex-col gap-5 flex-1">
					<h2 class="text-h2-section-serif group-hover:text-cerise-special transition-colors duration-200">{{ article.titre }}</h2>
					<p class="text-small">{{ article.chapeau | striptags | slice(0, 250) | split(' ') | slice(0, -1) | join(' ') ~ '...' }}</p>
					<div class="flex justify-between">
						<small>{{ formatDateFr(article.date_publication) }}</small>
						<small class="text-cerise-06">{{ article.rubrique_nom ?? article.rubrique }}</small>
					</div>
				</div>
			</a>
		{% endfor %}

		{% if gridArticles | length > 3 %}
			<div class="flex justify-center mt-10">
				{% include 'components/button.html.twig' with {
					label: 'Voir plus',
					href: base ~ '/articles'
				} %}
			</div>
		{% endif %}
	</section>
{% endif %}
