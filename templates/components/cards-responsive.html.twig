{# Carte article cliquable — page d'accueil #}
{# Paramètres :
   - href (string)        : lien vers l'article
   - image (string)       : nom du fichier image (assets/images/)
   - category (string)    : rubrique
   - title (string)       : titre
   - description (string) : chapeau
   - mobileLayout ('normal' | 'horizontal', défaut 'normal') :
       disposition sur MOBILE uniquement.
       Tablette (md) = toujours vertical · Desktop (lg) = toujours horizontal #}

{% set mHoriz = mobileLayout|default('normal') == 'horizontal' %}

<a href="{{ href }}" class="group flex gap-4 md:gap-5 lg:gap-6 {{ mHoriz ? 'flex-row' : 'flex-col' }} md:flex-col lg:flex-row">
	<div class="rounded-md overflow-hidden shrink-0 {{ mHoriz ? 'w-1/3 self-stretch' : 'w-full aspect-5/3' }} md:w-full md:aspect-5/3 md:self-auto lg:w-1/3 lg:aspect-auto lg:self-stretch">
		<img src="{{ base }}/assets/images/{{ image }}" alt="{{ title }}" class="w-full h-full object-cover">
	</div>
	<div class="flex flex-col gap-5 {{ mHoriz ? 'flex-1' : '' }} md:flex-none lg:flex-1">
		<div>
			<p class="text-sat-info text-neutral-950 pb-2">{{ category }}</p>
			<h3 class="text-sat-h3 text-neutral-950 group-hover:underline">{{ title }}</h3>
		</div>
		<p class="text-sat-base text-neutral-600 line-clamp-3">{{ description }}</p>
	</div>
</a>
