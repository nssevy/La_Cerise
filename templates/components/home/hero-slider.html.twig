{# Slider hero — 2 articles max, navigation par boutons (pas de drag). #}
{# Paramètres : slides (array d'articles, 2 max). #}
{# Mobile : scroll horizontal de cartes verticales. Tablette/desktop : deck empilé (profondeur). #}
{% import 'macros/icons.html.twig' as icons %}

{% if slides is defined and slides is not empty %}
	<section data-hero-slider class="flex flex-col mb-10">

		{# ── Mobile : piste scrollable de cartes verticales ── #}
		<div data-hero-track class="flex md:hidden gap-4 overflow-x-hidden -mx-3.5 px-3.5">
			{% for slide in slides %}
				<div class="shrink-0 flex w-[90%]">
					{% include 'components/home/hero/hero-vertical.html.twig' with { hero: slide } %}
				</div>
			{% endfor %}
		</div>

		{# ── Tablette / desktop : deck empilé (article courant devant, suivant plus petit décalé à droite) ── #}
		<div data-hero-deck class="relative hidden md:block md:w-[92%] lg:w-[84%] md:mx-auto h-[45dvh] max-h-120 overflow-hidden">
			{% for slide in slides %}
				<div data-hero-card class="absolute top-0 left-0 h-full w-[80%] lg:w-[78%]">
					{% include 'components/home/hero/hero-horizontal.html.twig' with { hero: slide } %}
				</div>
			{% endfor %}

			{# Flèche unique — desktop uniquement, centrée verticalement sur l'article de devant #}
			<button type="button" data-hero-cycle aria-label="Article suivant" class="hidden lg:flex absolute top-1/2 right-2 z-30 -translate-y-1/2 items-center justify-center w-10 h-10 rounded-full bg-cerise-special text-cerise-10 shadow-lg transition-colors hover:bg-cerise-special-dark cursor-pointer">
				{{ icons.icon('arrow-right', 'bold', 'w-4 h-4') }}
			</button>
		</div>

		{# ── Contrôles mobile/tablette (pilule 2 flèches) — masqués sur desktop ── #}
		<div class="flex lg:hidden items-center justify-between py-10">
			<span class="text-sat-base text-neutral-300">Articles Récents</span>

			<div class="flex items-center gap-1 rounded-full border border-neutral-300 p-1.5">
				<button type="button" data-hero-prev aria-label="Article précédent" class="flex items-center justify-center w-10 h-7 rounded-full text-neutral-700 transition-colors hover:bg-neutral-100 disabled:opacity-30 cursor-pointer disabled:cursor-not-allowed disabled:hover:bg-transparent">
					{{ icons.icon('arrow-left', 'bold', 'w-4 h-4') }}
				</button>
				<button type="button" data-hero-next aria-label="Article suivant" class="flex items-center justify-center w-10 h-7 rounded-full text-neutral-700 transition-colors hover:bg-neutral-100 disabled:opacity-30 cursor-pointer disabled:cursor-not-allowed disabled:hover:bg-transparent">
					{{ icons.icon('arrow-right', 'bold', 'w-4 h-4') }}
				</button>
			</div>
		</div>
	</section>
{% endif %}
