{# CTA "Tu veux lire plus d'articles ?" #}
{# Paramètres :
   - images (array) : noms de fichiers images (assets/images/) pour le collage
   Mobile : titre / collage / bouton (colonne)
   Desktop : titre + bouton à gauche, collage à droite (effet accordéon au survol) #}

<section class="flex flex-col gap-8 rounded-2xl border border-cerise-special p-8 lg:grid lg:grid-cols-2 lg:items-start lg:gap-x-12 lg:gap-y-6 lg:p-12">

	<h2 class="order-1 text-sat-h1 lg:col-start-1 lg:row-start-1">
		Tu veux lire plus <span class="text-gradient">d'articles ?</span>
	</h2>

	{# Collage : bandes d'images, la survolée s'élargit légèrement (desktop) #}
	<div class="order-2 flex h-44 gap-2 overflow-hidden lg:col-start-2 lg:row-start-1 lg:row-span-2 lg:h-auto lg:self-stretch">
		{% for img in images %}
			<div class="relative overflow-hidden rounded-md transition-all duration-500 ease-out {{ loop.first ? 'flex-[4] lg:hover:flex-[4.6]' : 'flex-1 lg:hover:flex-[1.6]' }} {{ loop.index > 4 ? 'hidden lg:block' : '' }}">
				<img src="{{ base }}/assets/images/{{ img }}" alt="" class="h-full w-full object-cover">
			</div>
		{% endfor %}
	</div>

	{# Bouton #}
	<div class="order-3 lg:col-start-1 lg:row-start-2">
		{% include 'components/button-cta.html.twig' with { label: 'Clique ici !', href: base ~ '/articles' } %}
	</div>
</section>
