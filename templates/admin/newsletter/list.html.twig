{% extends 'admin/base.html.twig' %}
{% import 'macros/icons.html.twig' as icons %}
{% block titre %}Newsletter
{% endblock %}

{% block content %}

	<div class="px-7 md:px-10 md:pt-10 pb-4 flex flex-row justify-between gap-2">
		<h1 class="text-4xl text-gradient">Newsletter</h1>
		<p class="text-cerise-05 text-sm">{{ inscrits|length }}
			inscrit{{ inscrits|length > 1 ? 's' : '' }}</p>
	</div>

	{% if inscrits is empty %}
		<div class="flex flex-col items-center justify-center gap-4 py-32 text-cerise-05">
			<p>Aucun inscrit pour le moment.</p>
		</div>
	{% else %}
		{% for inscrit in inscrits %}
			<div class="flex flex-col md:flex-row gap-2 md:gap-0 py-8 hover:bg-cerise-10 transition-colors px-7 md:px-10 group ">

				<div class="md:w-1/3 flex flex-row justify-between md:justify-start md:flex-col gap-1 text-sm">
					<time class="text-cerise-05" datetime="{{ inscrit.date_inscription }}">
						{{ formatDateFr(inscrit.date_inscription) }}
					</time>
				</div>

				<div class="md:w-2/3 flex flex-row items-center justify-between gap-2">
					<span class="font-medium text-cerise-01">{{ inscrit.email }}</span>

					<form method="POST" action="{{ base }}/admin/newsletter/delete" onsubmit="return confirm('Désinscrire {{ inscrit.email }} ?')">
						<input type="hidden" name="csrf_token" value="{{ csrf_token }}">
						<input type="hidden" name="id" value="{{ inscrit.id }}">
						<button type="submit" class="text-sm text-red-800 hover:text-red-500 transition-colors cursor-pointer">
							Supprimer
						</button>
					</form>
				</div>

			</div>
		{% endfor %}
	{% endif %}

	<script src="{{ base }}/assets/js/confirm.js" defer></script>

{% endblock %}
