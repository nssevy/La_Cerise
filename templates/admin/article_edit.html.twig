{% extends 'admin/base.html.twig' %}
{% import 'macros/icons.html.twig' as icons %}

{% block titre %}Modifier —
	{{ article.titre }}
{% endblock %}

{% block scripts %}
	<script src="https://cdn.tiny.cloud/1/l5emzp4vl5hfv2tvrlmvuk4u9eji40glpnxuc559gkadzi4r/tinymce/7/tinymce.min.js" referrerpolicy="origin"></script>
	<script src="{{ base }}/assets/js/tinymce-init.js"></script>
	<script src="{{ base }}/assets/js/dropzone.js" defer></script>
{% endblock %}

{% block content %}
	<nav>
		{% include 'components/breadcrumb.html.twig' with {
        'breadcrumb': [
            {'label': 'modifier un article', 'url': null}
        ]
    } %}
	</nav>
	<div class="mt-10 md:max-w-2xl md:mx-auto">
		<div class="flex flex-col gap-2 mb-30">
			<p class="text-center text-cerise-05">Vous etes entrain de modifier :</p>
			<h1 class="text-3xl text-center text-gradient">{{ article.titre }}</h1>
		</div>

		{% if errors %}
			<aside role="alert">
				<ul>
					{% for error in errors %}
						<li>{{ error }}</li>
					{% endfor %}
				</ul>
			</aside>
		{% endif %}

		<form class="flex flex-col gap-10" method="POST" action="" novalidate>

			<fieldset class="grid gap-10">
				{% include 'admin/partials/contenteditable-field.html.twig' with {
				label: 'Titre',
				name: 'titre',
				value: article.titre,
				required: true,
				class: 'text-lg'
				} only %}

				<hr class="border-t border-cerise-09/60">

				{% include 'admin/partials/contenteditable-field.html.twig' with {
				label: 'Chapeau',
				name: 'chapeau',
				value: article.chapeau,
				required: true,
				class: 'text-lg'
				} only %}

				<div>
					<label for="contenu" class="text-cerise-05">Contenu
						<abbr title="Champ obligatoire">*</abbr>
					</label>
					<textarea id="contenu" name="contenu" rows="20">{{ article.contenu }}</textarea>
				</div>

			</fieldset>

			<fieldset class="grid gap-10">

				<div class="flex flex-col gap-2">
					<label class="text-cerise-05" for="rubrique_id">Rubrique</label>
					<select id="rubrique_id" name="rubrique_id" class="select w-full">
						<option value="">— Choisir une rubrique —</option>
						{% for rubrique in rubriques %}
							<option value="{{ rubrique.id }}" {{ article.rubrique_id == rubrique.id ? 'selected' : '' }}>
								{{ rubrique.nom }}
							</option>
						{% endfor %}
					</select>
				</div>

				<div class="flex flex-col gap-2">
					<label class="text-cerise-05" for="auteur_id">Auteur</label>
					<select id="auteur_id" name="auteur_id" class="select w-full">
						<option value="">— Choisir un auteur —</option>
						{% for auteur in auteurs %}
							<option value="{{ auteur.id }}" {{ article.auteur_id == auteur.id ? 'selected' : '' }}>
								{{ auteur.nom }}
							</option>
						{% endfor %}
					</select>
				</div>

				<hr class="border-t border-cerise-09/60">

				<div class="flex flex-col gap-2">
					<label class="text-cerise-05" for="statut">Statut</label>
					<select id="statut" name="statut" class="select w-full">
						<option value="brouillon" {{ article.statut == 'brouillon' ? 'selected' : '' }}>Brouillon</option>
						<option value="publie" {{ article.statut == 'publie' ? 'selected' : '' }}>Publié</option>
						<option value="a_venir" {{ article.statut == 'a_venir' ? 'selected' : '' }}>À venir</option>
						<option value="archive" {{ article.statut == 'archive' ? 'selected' : '' }}>Archivé</option>
					</select>
				</div>

				<hr class="border-t border-cerise-09/60">

				<div class="flex flex-col gap-2">
					<label class="text-cerise-05" for="date_publication">Date de publication</label>
					<input type="date" class="input w-full" id="date_publication" name="date_publication" value="{{ article.date_publication ? article.date_publication|date('Y-m-d\\TH:i') : '' }}">
				</div>
				<hr class="border-t border-cerise-09/60">

			</fieldset>

			<fieldset class="grid gap-10">
				<div>
					<label class="text-cerise-05">Image principale</label>
					<div id="dropzone" class="flex flex-col items-center justify-center gap-3 border border-dashed border-cerise-09 rounded-lg p-10 cursor-pointer hover:bg-cerise-10 transition">
						<p>Glissez votre image ici ou
							<span class="text-cerise-04 underline">parcourir</span>
						</p>
						<small class="text-cerise-05">JPEG, PNG</small>
						<div id="dropzone-preview"></div>
					</div>
					<input type="file" id="image_principale" name="image_principale" accept=".jpg,.jpeg,.png" class="hidden">
				</div>
				<hr class="border-t border-cerise-09/60">

				{% include 'admin/partials/contenteditable-field.html.twig' with {
				label: 'Crédit photo',
				name: 'credit_photo',
				value: article.credit_photo,
				required: false,
				class: 'text-base'
			} only %}


			</fieldset>
			{# État initial #}
			<div id="form-actions-clean" class="mt-20 w-full">
				{% include 'components/button.html.twig' with { 
				label: "Retour",
				href: base ~ "/admin/article/list",
				class: "w-full"
			} %}
			</div>

			{# État modifié #}
			<div id="form-actions-dirty" class="hidden flex flex-rows gap-5 mt-20 w-full">
				{% include 'components/button.html.twig' with { 
				label: "Annuler",
				href: base ~ "/admin/article/list",
				class: "w-full"
			} %}
				{% include 'components/button.html.twig' with { 
				label: "Enregistrer les modifications",
				type: "submit",
				class: "w-full"
			} %}
			</div>


		</form>
	</div>

{% endblock %}
