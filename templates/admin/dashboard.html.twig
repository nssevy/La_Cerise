{% extends 'admin/base.html.twig' %}
{% import 'macros/icons.html.twig' as icons %}
{% block titre %}L'espace Admin
{% endblock %}

{% block content %}

	<section class="grid grid-cols-3 grid-rows-1">
		{% for article in articles %}
			<a href="{{ base }}/admin/article/edit?id={{ article.id }}" class="flex flex-col px-10 py-10 border border-cerise-09 min-h-[60svh] justify-between">
				<div>
					<p>
						{{ article.statut }}
					</p>
					<h2 class="text-h2-section">
						{{ article.titre }}
					</h2>
					<p>
						{{ article.chapeau }}
					</p>
				</div>

				<div>
					{{ article.rubrique ?? 'Non classé' }}
					{{ article.date_publication ? article.date_publication|date('d/m/Y') : '—' }}
				</div>
			</a>
		{% else %}
			<p>Aucun article pour le moment</p>
		{% endfor %}

	</section>

	<tr>
		<td>{{ article.titre }}</td>
		<td>{{ article.rubrique ?? 'Non classé' }}</td>
		<td>{{ article.statut }}</td>
		<td>{{ article.date_publication ? article.date_publication|date('d/m/Y') : '—' }}</td>
		<td>
			<a href="{{ base }}/admin/article/edit?id={{ article.id }}">Éditer</a>
			<form method="POST" action="{{ base }}/admin/article_delete" style="display:inline;">
				<input type="hidden" name="id" value="{{ article.id }}">
				<button type="submit" data-action="confirm-delete">Supprimer</button>
			</form>
		</td>
	</tr>
	<script src="/La_Cerise/assets/js/confirm.js" defer></script>
{% endblock %}
