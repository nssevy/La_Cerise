{% extends 'admin/base.html.twig' %}
{% import 'macros/icons.html.twig' as icons %}

{% block titre %}Modifier —
	{{ rubrique.nom }}
{% endblock %}

{% block content %}
	<nav>
		{% include 'components/breadcrumb.html.twig' with {
            'breadcrumb': [
                {'label': 'Paramètres', 'url': base ~ '/admin/parametre'},
                {'label': rubrique.nom, 'url': null}
            ]
        } %}
	</nav>

	<div class="mt-10 md:max-w-2xl md:mx-auto">

		<div class="flex flex-col gap-2 mb-30">
			<p class="text-center text-cerise-05">Vous êtes en train de modifier :</p>
			<h1 class="text-3xl text-center text-gradient">{{ rubrique.nom }}</h1>
		</div>

		{% if errors is defined and errors|length > 0 %}
			<aside role="alert">
				<ul>
					{% for error in errors %}
						<li>{{ error }}</li>
					{% endfor %}
				</ul>
			</aside>
		{% endif %}

		<form class="flex flex-col gap-10" method="POST" action="{{ base }}/admin/parametre/rubrique/edit?id={{ rubrique.id }}" novalidate>
			<input type="hidden" name="csrf_token" value="{{ csrf_token }}">

			<fieldset class="grid gap-10">

				{% include 'admin/partials/contenteditable-field.html.twig' with {
                    label: 'Nom',
                    name: 'nom',
                    value: rubrique.nom ?? '',
                    required: true,
                    class: 'text-lg'
                } only %}

				{% include 'admin/partials/contenteditable-field.html.twig' with {
                    label: 'Définition',
                    name: 'description',
                    value: rubrique.description ?? '',
                    required: false,
                    class: 'text-lg'
                } only %}


			</fieldset>

			<div class="mt-20 w-full flex flex-col md:flex-row gap-5">
				{% include 'components/button.html.twig' with {
					label: "Enregistrer les modifications",
					type: "submit",
					class: "w-full md:order-last"
				} %}
				{% include 'components/button.html.twig' with {
					label: "Retour",
					href: base ~ "/admin/parametre",
					class: "w-full md:order-first"
				} %}
			</div>
			<button type="button" class="text-sm text-red-800 hover:text-red-500 transition-colors" onclick="if(confirm('Supprimer ce thème ?')) document.getElementById('form-delete-rubrique').submit();">
				Supprimer le thème
			</button>


		</form>
		<form method="POST" action="{{ base }}/admin/parametre/rubrique/delete" id="form-delete-rubrique" class="hidden">
			<input type="hidden" name="csrf_token" value="{{ csrf_token }}">
			<input type="hidden" name="id" value="{{ rubrique.id }}">
		</form>
	</div>
{% endblock %}
