{% extends 'admin/base.html.twig' %}
{% import 'macros/icons.html.twig' as icons %}
{% block titre %}Lexique
{% endblock %}

{% block content %}

	<div class="px-7 md:px-10 pt-10 pb-4 flex flex-col gap-2">
		<h1 class="text-h1">
			{% if categorie_id %}
				{% for categorie in categories %}
					{% if categorie.id == categorie_id %}
						{{ categorie.nom }}
					{% endif %}
				{% endfor %}
			{% else %}
				Tous
			{% endif %}
		</h1>
	</div>

	<div class="px-7 md:px-10 flex gap-6 border-b border-cerise-09 overflow-x-auto">
		<a href="{{ base }}/admin/lexique/list" class="py-4 text-sm whitespace-nowrap border-b-2 transition-colors {{ categorie_id is null ? 'border-cerise-01 text-cerise-01 font-medium' : 'border-transparent text-cerise-05 hover:text-cerise-02' }}">
			Tous
		</a>
		{% for categorie in categories %}
			<a href="{{ base }}/admin/lexique/list?categorie={{ categorie.id }}" class="py-4 text-sm whitespace-nowrap border-b-2 transition-colors {{ categorie_id == categorie.id ? 'border-cerise-01 text-cerise-01 font-medium' : 'border-transparent text-cerise-05 hover:text-cerise-02' }}">
				{{ categorie.nom }}
			</a>
		{% endfor %}
	</div>

	{% include 'admin/lexique/bloc/sectionLexique.html.twig' %}

	<div class="md:flex fixed bottom-6 left-1/2 -translate-x-1/2 z-50">
		<a href="{{ base }}/admin/lexique/create">
			{% include 'components/button.html.twig' with { label: "Nouveau terme" } %}
		</a>
	</div>

	<script src="{{ base }}/assets/js/confirm.js" defer></script>

{% endblock %}
