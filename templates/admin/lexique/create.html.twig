{% extends 'admin/base.html.twig' %}
{% block titre %}Nouveau terme — Lexique
{% endblock %}

{% block content %}

	<nav>
		{% include 'components/breadcrumb.html.twig' with {
      'breadcrumb': [
        {'label': 'Créer une définition', 'url': null}
      ]
    } %}
	</nav>

	<div class="mt-10 md:max-w-2xl md:mx-auto">

		<div class="flex flex-col gap-2 mb-10 md:mb-20">
			<h1 class="text-3xl text-center text-gradient">Nouveau terme</h1>
		</div>

		<div class="px-7 md:px-10 py-10 max-w-2xl">

			{% if errors is defined and errors|length %}
				<ul class="flex flex-col gap-1 mb-8 p-4 border border-red-300 bg-red-50 rounded text-sm text-red-800">
					{% for error in errors %}
						<li>{{ error }}</li>
					{% endfor %}
				</ul>
			{% endif %}

			{% include 'admin/lexique/form.html.twig' with {
			terme: {},
			categories: categories,
			submit_label: "Créer le terme"
		} only %}
		</div>

	</div>


{% endblock %}
