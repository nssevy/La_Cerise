{% extends 'admin/base.html.twig' %}
{% block titre %}Éditer —
	{{ terme.terme }}
{% endblock %}

{% block content %}

	<div class="px-7 md:px-10 pt-10 pb-4 border-b border-cerise-09">
		<h1 class="text-h1">{{ terme.terme }}</h1>
		<p class="text-cerise-05 text-sm mt-1">{{ terme.categorie_nom ?: 'Sans catégorie' }}</p>
	</div>

	<div class="px-7 md:px-10 py-10 max-w-2xl">

		{% if errors is defined and errors|length %}
			<ul class="flex flex-col gap-1 mb-8 p-4 border border-red-300 bg-red-50 rounded text-sm text-red-800">
				{% for error in errors %}
					<li>{{ error }}</li>
				{% endfor %}
			</ul>
		{% endif %}

		{% include 'admin/lexique/form.html.twig' with {
			terme: terme,
			categories: categories,
			submit_label: "Enregistrer les modifications",
			show_delete: true
		} only %}
	</div>

{% endblock %}
