<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Nouvel article — Admin La Cerise</title>
		<script src="https://cdn.tiny.cloud/1/l5emzp4vl5hfv2tvrlmvuk4u9eji40glpnxuc559gkadzi4r/tinymce/7/tinymce.min.js" referrerpolicy="origin"></script>
		<script src="{{ base }}/assets/js/tinymce-init.js"></script>
	</head>
	<body>

		<h1>Nouvel article</h1>
		<a href="{{ base }}/admin/article/list">Retour au dashboard</a>

		{% if errors %}
			<ul>
				{% for error in errors %}
					<li>{{ error }}</li>
				{% endfor %}
			</ul>
		{% endif %}

		<form method="POST" action="">

			<div>
				<label for="titre">Titre *</label>
				<input type="text" id="titre" name="titre" required>
			</div>

			<div>
				<label for="chapeau">Chapeau</label>
				<textarea id="chapeau" name="chapeau" rows="3"></textarea>
			</div>

			<div>
				<label for="contenu">Contenu *</label>
				<textarea id="contenu" name="contenu" rows="20"></textarea>
			</div>

			<div>
				<label for="rubrique_id">Rubrique</label>
				<select id="rubrique_id" name="rubrique_id">
					<option value="">— Choisir une rubrique —</option>
					{% for rubrique in rubriques %}
						<option value="{{ rubrique.id }}">{{ rubrique.nom }}</option>
					{% endfor %}
				</select>
			</div>

			<div>
				<label for="auteur_id">Auteur</label>
				<select id="auteur_id" name="auteur_id">
					<option value="">— Choisir un auteur —</option>
					{% for auteur in auteurs %}
						<option value="{{ auteur.id }}">{{ auteur.nom }}</option>
					{% endfor %}
				</select>
			</div>

			<div>
				<label for="image_principale">Image principale (nom du fichier)</label>
				<input type="text" id="image_principale" name="image_principale" placeholder="ex: mon-image.jpg">
			</div>

			<div>
				<label for="credit_photo">Crédit photo</label>
				<input type="text" id="credit_photo" name="credit_photo">
			</div>

			<div>
				<label for="statut">Statut</label>
				<select id="statut" name="statut">
					<option value="brouillon">Brouillon</option>
					<option value="publie">Publié</option>
					<option value="a_venir">À venir</option>
					<option value="archive">Archivé</option>
				</select>
			</div>

			<div>
				<label for="date_publication">Date de publication</label>
				<input type="datetime-local" id="date_publication" name="date_publication">
			</div>

			<button type="submit">Créer l'article</button>

		</form>

	</body>
</html>
