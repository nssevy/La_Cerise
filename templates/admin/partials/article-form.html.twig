<form class="flex flex-col gap-10" method="POST" action="" novalidate enctype="multipart/form-data">
	<input type="hidden" name="csrf_token" value="{{ csrf_token }}">
	<fieldset class="grid gap-10">
		{% include 'admin/partials/contenteditable-field.html.twig' with {
      label: 'Titre',
      name: 'titre',
      value: article.titre ?? '',
      required: true,
      class: 'text-lg'
    } only %}

		{% include 'admin/partials/contenteditable-field.html.twig' with {
      label: 'Chapeau',
      name: 'chapeau',
      value: article.chapeau ?? '',
      required: true,
      class: 'text-lg'
    } only %}

		<div>
			<label for="contenu" class="text-cerise-01">Contenu
				<abbr title="Champ obligatoire">*</abbr>
			</label>
			<textarea id="contenu" name="contenu" rows="20">{{ article.contenu ?? '' }}</textarea>
		</div>

	</fieldset>

	<fieldset class="grid gap-10">

		<div class="flex flex-col gap-3">
			<label class="text-cerise-01">Rubrique</label>
			<div class="flex flex-row flex-wrap gap-2">
				{% for rubrique in rubriques %}
					<label class="cursor-pointer">
						<input type="radio" name="rubrique_id" value="{{ rubrique.id }}" {{ (article.rubrique_id ?? '') == rubrique.id ? 'checked' : '' }} class="hidden peer">
						<span class="btn btn-md btn-outline peer-checked:text-cerise-10 peer-checked:bg-(--03)">
							{{ rubrique.nom }}
						</span>
					</label>
				{% endfor %}
			</div>
		</div>

		<div class="flex flex-col gap-2">
			<label class="text-cerise-01" for="auteur_id">Auteur</label>
			<select id="auteur_id" name="auteur_id" class="select w-full">
				<option value="" class="text-cerise-05">Aucun auteur choisis</option>
				{% for auteur in auteurs %}
					<option value="{{ auteur.id }}" {{ (article.auteur_id ?? '') == auteur.id ? 'selected' : '' }}>
						{{ auteur.nom }}
					</option>
				{% endfor %}
			</select>
		</div>

		<div class="flex flex-col gap-3">
			<label class="text-cerise-01">Statut</label>
			<div class="flex flex-row flex-wrap gap-2">
				{% set statuts = [
					{ value: 'brouillon', label: 'Brouillon' },
					{ value: 'publie',    label: 'Publié' },
					{ value: 'a_venir',   label: 'À venir' },
					{ value: 'archive',   label: 'Archivé' }
				] %}
				{% for s in statuts %}
					<label class="cursor-pointer">
						<input type="radio" name="statut" value="{{ s.value }}" {{ (article.statut ?? 'brouillon') == s.value ? 'checked' : '' }} class="hidden peer">
						<span class="btn btn-md btn-outline peer-checked:text-cerise-10 peer-checked:bg-(--03)">
							{{ s.label }}
						</span>
					</label>
				{% endfor %}
			</div>
		</div>

		<div class="flex flex-col gap-2">
			<label class="text-cerise-01">Date de publication</label>
			{% set date_val = article.date_publication ? article.date_publication|date('Y-m-d') : '' %}
			<input type="hidden" id="date_publication" name="date_publication" value="{{ date_val }}">
			<button type="button" popovertarget="cally-popover-date" class="input input-border text-left w-full" id="cally-btn" style="anchor-name:--cally-date">
				{{ date_val ? article.date_publication|date('d/m/Y') : 'Choisir une date' }}
			</button>
			<div popover id="cally-popover-date" class="dropdown bg-base-100 rounded-box shadow-lg" style="position-anchor:--cally-date">
				<calendar-date class="cally" value="{{ date_val }}" onchange="
																																																																													document.getElementById('date_publication').value = this.value;
																																																																													document.getElementById('cally-btn').innerText = this.value.split('-').reverse().join('/');
																																																																													document.getElementById('cally-popover-date').hidePopover();
																																																																												">
					<svg aria-label="Précédent" class="fill-current size-4" slot="previous" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24">
						<path d="M15.75 19.5 8.25 12l7.5-7.5"></path>
					</svg>
					<svg aria-label="Suivant" class="fill-current size-4" slot="next" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24">
						<path d="m8.25 4.5 7.5 7.5-7.5 7.5"></path>
					</svg>
					<calendar-month></calendar-month>
				</calendar-date>
			</div>
		</div>

	</fieldset>

	<fieldset class="grid gap-10">

		<div>
			<label class="text-cerise-01">Image principale</label>

			{% if article.image_principale is defined and article.image_principale %}
				<div class="mb-3 flex flex-col gap-2">
					<small class="text-cerise-05">Image actuelle</small>
					<img src="{{ base }}/assets/images/{{ article.image_principale }}" alt="Image actuelle" class="w-full max-h-48 object-cover rounded">
				</div>
			{% endif %}

			<div id="dropzone" class="flex flex-col items-center justify-center gap-3 border border-dashed border-cerise-09 rounded-lg p-10 cursor-pointer hover:bg-cerise-10 transition">
				<p>Glissez votre image ici ou
					<span class="text-cerise-04 underline">parcourir</span>
				</p>
				<small class="text-cerise-05">JPEG, PNG</small>
				<div id="dropzone-preview"></div>
			</div>
			<input type="file" id="image_principale" name="image_principale" accept=".jpg,.jpeg,.png" class="hidden">
		</div>

		{% include 'admin/partials/contenteditable-field.html.twig' with {
      label: 'Crédit photo',
      name: 'credit_photo',
      value: article.credit_photo ?? '',
      required: false,
      class: 'text-base'
    } only %}

	</fieldset>

	<div class="mt-20 w-full flex flex-col md:flex-row gap-5">
		{% include 'components/button.html.twig' with {
        label: submit_label ?? "Enregistrer",
        type: "submit",
        class: "w-full md:order-last"
    } %}
		{% include 'components/button.html.twig' with {
        label: "Retour",
        href: base ~ "/admin/article/list",
        class: "w-full md:order-first"
    } %}
	</div>

	{% if show_delete is defined and show_delete %}
		<button type="button" class="text-sm text-red-800 hover:text-red-500 transition-colors cursor-pointer" onclick="if(confirm('Supprimer cet article ?')) document.getElementById('form-delete-article').submit();">
			Supprimer l'article
		</button>
	{% endif %}

</form>

{% if show_delete is defined and show_delete %}
	<form method="POST" action="{{ base }}/admin/article/delete" id="form-delete-article" class="hidden">
		<input type="hidden" name="csrf_token" value="{{ csrf_token }}">
		<input type="hidden" name="id" value="{{ article.id }}">
	</form>
{% endif %}
