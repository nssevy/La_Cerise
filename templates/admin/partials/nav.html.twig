{% set links = [
    { label: 'Articles', href: base ~ '/admin/article/list', section: 'articles' },
    { label: 'Lexique', href: base ~ '/admin/lexique/list', section: 'lexique' },
    { label: 'Newsletter', href: base ~ '/admin/newsletter/list', section: 'newsletter' },
    { label: 'Paramètre', href: base ~ '/admin/parametre', section: 'parametre' },
] %}
<div class="flex justify-center">
	<nav class="inline-flex items-center bg-cerise-10 rounded-full border border-cerise-05 p-1 gap-1">
		{% for link in links %}
			<a href="{{ link.href }}" class="{{ section == link.section ? 'bg-cerise-01 text-cerise-10' : 'text-cerise-01 hover:bg-cerise-01/10' }} px-5 py-2 rounded-full text-sm transition-colors">
				{{ link.label }}
			</a>
		{% endfor %}
	</nav>
</div>
