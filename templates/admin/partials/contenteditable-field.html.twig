<div class="flex flex-col items-start">
	<label class="text-cerise-05">{{ label }}
		{% if required %}
			<abbr title="Champ obligatoire">*</abbr>
		{% endif %}
	</label>
	<div contenteditable="true" data-contenteditable="{{ name }}" class="outline-none {{ class }}">{{ value }}</div>
	<input type="hidden" id="{{ name }}" name="{{ name }}" value="{{ value }}">
</div>
