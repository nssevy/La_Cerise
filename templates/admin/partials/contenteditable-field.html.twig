{# admin/partials/contenteditable-field.html.twig #}
<div class="flex flex-col items-start">
	<label>{{ label }}
		{% if required %}
			<abbr title="Champ obligatoire">*</abbr>
		{% endif %}
	</label>
	<div contenteditable="true" data-contenteditable="{{ name }}" class="outline-none border-b border-dashed border-cerise-09 min-h-[1.5em] w-full {{ class ?? '' }}">{{ value }}</div>
	<input type="hidden" id="{{ name }}" name="{{ name }}" value="{{ value }}">
</div>
