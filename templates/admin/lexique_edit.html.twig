<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Modifier un terme — Admin La Cerise</title>
	</head>
	<body>

		<h1>Modifier un terme</h1>
		<a href="{{ base }}/admin/lexique/list">Retour au lexique</a>

		{% if errors %}
			<ul>
				{% for error in errors %}
					<li>{{ error }}</li>
				{% endfor %}
			</ul>
		{% endif %}

		<form method="POST" action="">
			<div>
				<label for="terme">Terme *</label>
				<input type="text" id="terme" name="terme" value="{{ terme.terme }}" required>
			</div>
			<div>
				<label for="definition">Définition *</label>
				<textarea id="definition" name="definition" rows="5" required>{{ terme.definition }}</textarea>
			</div>
			<div>
				<label for="categorie">Catégorie</label>
				<input type="text" id="categorie" name="categorie" value="{{ terme.categorie ?? '' }}">
			</div>
			<button type="submit">Enregistrer</button>
		</form>

	</body>
</html>
