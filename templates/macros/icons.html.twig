{% macro icon(name, weight, class) %}
	{% set weight = weight|default('regular') %}
	{% set class = class|default('w-5 h-5') %}
	<span class="{{ class }} inline-flex items-center justify-center">
		{% set svg_content %}{% include 'icons/' ~ weight ~ '/' ~ name ~ '-' ~ weight ~ '.svg' %}{% endset %}
		{{ svg_content | replace({'<svg ': '<svg width="100%" height="100%" '}) | raw }}
	</span>
{% endmacro %}
