{% extends 'public/base.html.twig' %}

{% block titre %}La Cerise
{% endblock %}

{% block main_class %}
	<main class="max-w-7xl lg:mx-auto mx-3.5 mt-3.5">
	{% endblock %}

	{% block content %}
		{% import 'macros/icons.html.twig' as icons %}
		{# Section Header #}
		{% include 'components/home/hero.html.twig' with { hero: hero } %}
		{# Sections Quelque termes #}
		<section class="flex flex-col gap-5 lg:hidden">
			<h2 class="text-sat-h1">Quelques termes
				<br>
				<span class="text-gradient">de lexique</span>
			</h2>
			<div class="flex gap-6 md:gap-10 overflow-x-auto snap-x snap-mandatory pb-4">
				{% for item in lexique|slice(0, 4) %}
					{% include 'components/home/lexique-definition.html.twig' with { item: item } %}
				{% endfor %}
				<div class="flex items-center">
					{% include 'components/button-rounded.html.twig' with { label: "En savoir plus" } %}
				</div>
			</div>
		</section>
		{# Articles (3/4) + sidebar lexique (1/4, desktop uniquement) #}
		<div class="mt-15 lg:grid lg:grid-cols-4 lg:gap-8">
			<section
				class="flex flex-col gap-15 lg:gap-12 lg:col-span-3">

				{# Bloc 1 : 2 articles côte à côte #}
				<div class="grid grid-cols-1 md:grid-cols-2 gap-15">
					{% for card in cards %}
						{% include 'components/cards-responsive.html.twig' with {
						mobileLayout: loop.first ? 'normal' : 'horizontal',
						href: base ~ '/article/' ~ card.slug,
						image: card.image_principale,
						category: card.rubrique,
						title: card.titre,
						description: card.chapeau|striptags
					} %}
					{% endfor %}
				</div>

				{# Bloc 2 : 3ᵉ article horizontal (desktop uniquement) #}
				{% if gridArticles is not empty %}
					{% set a3 = gridArticles|first %}
					<hr class="hidden lg:block border-neutral-300">
					<div class="hidden lg:block">
						{% include 'components/cards-responsive.html.twig' with {
						mobileLayout: 'horizontal',
						href: base ~ '/article/' ~ a3.slug,
						image: a3.image_principale,
						category: a3.rubrique,
						title: a3.titre,
						description: a3.chapeau|striptags
					} %}
					</div>
				{% endif %}

				{# Bloc 3 : Pourquoi La Cerise #}
				<hr class="hidden lg:block border-neutral-300">
				{% include 'components/home/pourquoi-cerise.html.twig' %}

				{# Bloc 4 : articles après "Pourquoi" — 2 sur mobile/tablette, 1 sur desktop #}
				{% if gridArticles|length > 1 %}
					<hr
					class="hidden lg:block border-neutral-300">
					{# 1er article : déjà affiché en desktop (Bloc 2), donc mobile/tablette seulement #}
					<div class="lg:hidden">
						{% include 'components/cards-responsive.html.twig' with {
						mobileLayout: 'horizontal',
						tabletHorizontal: true,
						href: base ~ '/article/' ~ gridArticles[0].slug,
						image: gridArticles[0].image_principale,
						category: gridArticles[0].rubrique,
						title: gridArticles[0].titre,
						description: gridArticles[0].chapeau|striptags
					} %}
					</div>
					{# 2e article : tous formats, horizontal #}
					{% include 'components/cards-responsive.html.twig' with {
						mobileLayout: 'horizontal',
						tabletHorizontal: true,
						largeImageTablet: true,
						largeImageDesktop: true,
						href: base ~ '/article/' ~ gridArticles[1].slug,
						image: gridArticles[1].image_principale,
						category: gridArticles[1].rubrique,
						title: gridArticles[1].titre,
						description: gridArticles[1].chapeau|striptags
					} %}
				{% endif %}

				{# Bloc 5 : CTA "Tu veux lire plus d'articles ?" #}
				<hr class="hidden lg:block border-neutral-300">
				{% include 'components/home/cta-articles.html.twig' with { images: ctaImages } %}
			</section>

			{# Sidebar lexique : épouse la hauteur de la colonne articles, déborde coupé #}
			<aside class="hidden lg:block lg:col-span-1 relative">
				<div data-lexique-fit class="absolute inset-0 overflow-hidden flex flex-col gap-8 border p-5 border-neutral-300">
					{% for item in lexique %}
						{% include 'components/home/lexique-definition.html.twig' with { item: item, variant: 'sidebar' } %}
					{% endfor %}
				</div>
			</aside>
		</div>
		{# Newsletter #}
		{% include 'components/home/newsletter.html.twig' %}
		{# Citation #}
		<style>
			[data-typed-target].typing::after {
				content: '|';
				margin-left: 0.08em;
				font-weight: 300;
				animation: cerise-caret 1s steps(1) infinite;
			}
			@keyframes cerise-caret { 50% { opacity: 0; } }
		</style>
		<section class="flex items-center text-sat-base text-center h-[60dvh] mx-auto max-w-2xl">
			<p data-typed-target>Notre objectif n'est pas de rendre le droit neutre. C'est de le rendre lisible, pour ceux qui veulent comprendre le monde tel qu'il est.</p>
		</section>


		<script src="{{ base }}/assets/js/stagger.js" defer></script>
		<script src="{{ base }}/assets/js/lexique-sidebar.js" defer></script>
		<script src="{{ base }}/assets/js/typed.umd.js" defer></script>
		<script src="{{ base }}/assets/js/citation-typed.js" defer></script>

	{% endblock %}
